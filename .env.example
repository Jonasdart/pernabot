# Configurações do Pernabot / Pelada Bot

# Token do Bot no Telegram (obtenha com o @BotFather)
TELEGRAM_TOKEN=seu_telegram_token_aqui

# Domínio público com HTTPS configurado no Cloudflare
BASE_URL=https://pelada.duzz.store

# Token do Cloudflare Tunnel (obtido no Cloudflare Dashboard -> Zero Trust -> Tunnels)
CLOUDFLARE_TUNNEL_TOKEN=seu_cloudflare_tunnel_token_aqui
